# ============================================================
# Quiniela 2026 — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the DEV values.
# Never commit real credentials to version control.
#
# Environment loading order (Vite):
#   .env.local        → local dev (gitignored, highest priority)
#   .env              → committed defaults (placeholders only)
#
# Production (Cloudflare Pages):
#   Set VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, and VITE_APP_URL
#   directly in the Cloudflare Pages dashboard → Settings → Environment variables.
# ============================================================

# Supabase project URL (from Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (from Project Settings → API)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public URL of this app (used for redirect URLs, OG tags, etc.)
VITE_APP_URL=http://localhost:5173
